# Database Configuration Template
# Copy this file to db.properties and fill in your values:
#   cp db.properties.example db.properties
#
# For production, set environment variables instead:
#   DB_URL, DB_USERNAME, DB_PASSWORD

db.driver=com.mysql.cj.jdbc.Driver
db.url=jdbc:mysql://localhost:3306/shop_management?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
db.username=root
db.password=YOUR_PASSWORD_HERE
